rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Post Images ──
    // Any authenticated user can upload an image to post_images/.
    // Anyone (including unauthenticated) can read images (so they display in cards).
    match /post_images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024   // max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Fallback: deny everything else ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
